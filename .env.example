PORT=4000
NODE_ENV=development
MONGODB_URI="your-atlas-connection-string/mediorb"
JWT_ACCESS_SECRET="change-me-long-random"
JWT_REFRESH_SECRET="change-me-too-long-random"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Optional: stable Ed25519 keys for the health card (PEM). If absent, a keypair is generated at runtime.
HEALTHCARD_PRIVATE_KEY=
HEALTHCARD_PUBLIC_KEY=
